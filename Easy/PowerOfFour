class Solution {
    public boolean isPowerOfFour(int n) {
        int count = 0;
        int temp = n;
        if(n == 1) return true;
        while(n != 0){
            count++;
            n = n / 4;
        }
        int p = 1;
        for(int i = 0; i < count - 1; i++){
            p = p * 4;
        }
        System.out.println(p);
        if(temp == p) return true;
        return false;
        
    }
}
