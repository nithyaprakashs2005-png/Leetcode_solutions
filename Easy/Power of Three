class Solution {
    public boolean isPowerOfThree(int n) {
        int temp = n;
        int count = 0;
        while(temp!=0){
            count++;
            temp = temp / 3;
        }
        int p = 1;
        for(int i = 0; i < count - 1; i++){
            p = p * 3;
        }
        System.out.println(p);
        if(p == n) return true;
        return false;
    }
}
